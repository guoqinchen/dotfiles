#!/bin/bash
# dotfiles-sync — 一键同步 dotfiles 状态
# 用法: dotfiles-sync [message]
# 作用: 检查 homedir-manager 状态 + 提交 + 推送

set -eu

echo "==> 检查 dotfiles 状态..."
cd ~/git/dotfiles

# 先运行安全审计
if command -v homedir-manager &>/dev/null; then
  echo "==> 运行安全审计..."
  homedir-manager audit --secrets || {
    echo "==> 安全审计未通过! 请检查是否有密钥泄漏风险。"
    exit 1
  }
fi

# 检查 git 状态
if [[ -n $(git status --porcelain) ]]; then
  echo "==> 有未提交的变更:"
  git status --short
  echo ""
  echo "是否提交并推送? [y/N] "
  read -r confirm
  if [[ "$confirm" =~ ^[Yy]$ ]]; then
    # 只添加 manifest 中的文件和已跟踪文件的修改
    # 避免 git add -A 误添敏感文件
    git add --update
    echo "==> 提交并推送..."
    git commit -m "sync: ${1:-dotfiles 同步 $(date +%Y-%m-%d)}" && git push && echo "==> 已完成" || echo "==> 推送失败"
  else
    echo "==> 跳过提交"
  fi
else
  echo "==> 没有未提交的变更"
fi
