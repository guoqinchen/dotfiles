#!/bin/bash
# dotfiles-sync — 一键同步 dotfiles 状态
# 用法: dotfiles-sync [message]
# 作用: 检查 homedir-manager 状态 + 提交 + 推送

set -eu

echo "==> 检查 dotfiles 状态..."
cd ~/git/dotfiles

# 确保 git hooks 已安装（.git/hooks/ 无法通过 symlink 管理）
HOOK_SRC="hooks/pre-push"
HOOK_DST=".git/hooks/pre-push"
if [ -f "$HOOK_SRC" ]; then
  if [ ! -f "$HOOK_DST" ] || ! diff -q "$HOOK_SRC" "$HOOK_DST" >/dev/null 2>&1; then
    cp "$HOOK_SRC" "$HOOK_DST"
    chmod +x "$HOOK_DST"
    echo "==> 已安装 pre-push hook"
  fi
fi

# 先运行安全审计
if command -v homedir-manager &>/dev/null; then
  echo "==> 运行安全审计..."
  homedir-manager audit --secrets || {
    echo "==> 安全审计未通过! 请检查是否有密钥泄漏风险。"
    exit 1
  }
fi

# 检查 git 状态
if [[ -n $(git status --porcelain) ]]; then
  echo "==> 有未提交的变更:"
  git status --short
  echo ""
  echo "是否提交并推送? [y/N] "
  read -r confirm
  if [[ "$confirm" =~ ^[Yy]$ ]]; then
    # 1. 暂存已跟踪文件的修改（安全）
    git add --update
    # 2. 暂存 manifest 中列出的新文件/目录（manifest 是手写白名单，安全）
    while IFS= read -r line; do
      file=$(echo "$line" | awk '{print $1}')
      if [ -n "$file" ] && [ -e "$file" ]; then
        git add "$file" 2>/dev/null || true
      fi
    done < <(grep -v '^#' manifest | grep -v '^$' | grep -v '^merge-children')
    echo "==> 提交并推送..."
    git commit -m "sync: ${1:-dotfiles 同步 $(date +%Y-%m-%d)}" && git push && echo "==> 已完成" || echo "==> 推送失败"
  else
    echo "==> 跳过提交"
  fi
else
  echo "==> 没有未提交的变更"
fi
